                        "value": "application/json"
                    },
                    {
                        "key": "X-User-ID",
                        "value": "person_a_uuid"
                    }
                ],
                "body": {
                    "mode": "raw",
                    "raw": "{\n    \"toUserId\": \"person_b_uuid\",\n    \"amount\": 10.0,\n    \"description\": \"CO2 for services\"\n}"
