    "item": [
        {
            "name": "Create Wallet",
            "request": {
                "method": "POST",
                "header": [
                    {
                        "key": "Content-Type",
                        "value": "application/json"
                    }
                ],
                "body": {
                    "mode": "raw",
                    "raw": "{\n    \"userId\": \"person_c_uuid\",\n    \"co2Balance\": 100.0,\n    \"moneyBalance\": 500.0\n}"
                },
                "url": {
                    "raw": "http://localhost:8080/api/wallet/wallets",
                    "protocol": "http",
                    "host": [
                        "localhost"
                    ],
                    "port": "8080",
                    "path": [
                        "api",
                        "wallet",
                        "wallets"
                    ]
                }
            },
            "response": []
        },
        {
            "name": "Get Balance",
            "request": {
                "method": "GET",
                "header": [
